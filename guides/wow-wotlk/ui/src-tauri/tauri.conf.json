{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dad's MMO Lab - WoW 3.3.5a Server",
  "version": "0.1.0",
  "identifier": "com.dads-mmo-lab-wotlk.ui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WoW 3.3.5a Server | Dad's MMO Lab",
        "width": 1280,
        "height": 800,
        "center": true,
        "fullscreen": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
